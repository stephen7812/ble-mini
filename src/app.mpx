  --color-card: #12121E;
  --color-text: #E0E0E0;
  --color-text-secondary: #808099;
  --color-border: #1E1E35;
}
.page.dark { background: var(--color-bg); }
.page.dark .card { background: var(--color-card); border: 1rpx solid rgba(0,255,65,0.06); }
