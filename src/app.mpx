  text-align: center; font-size: 28rpx;
}
.btn-primary:active { opacity: 0.8; }
.btn-outline {
  border: 2rpx solid var(--color-primary); color: var(--color-primary);
  border-radius: var(--radius); padding: 18rpx 48rpx;
  text-align: center; font-size: 28rpx; background: transparent;
}
.tag {
  display: inline-block; padding: 4rpx 16rpx;
  border-radius: 8rpx; font-size: 22rpx;
}
.tag-success { background: #e8faf0; color: #00b578; }
.tag-warning { background: #fff3e8; color: #ff8f1f; }
.tag-error { background: #ffeeed; color: #ff3141; }

