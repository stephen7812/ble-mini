.page.dark .btn-send:active { background: rgba(0,255,65,0.08); }
.page.dark .status-tag.on { background: rgba(0,255,65,0.1); color: var(--color-primary); }
.page.dark .status-tag.off { background: #1a1a2e; color: var(--color-text-secondary); }
