<script>
import { createApp } from '@mpxjs/core'
import { createPinia } from '@mpxjs/pinia'
import { useDeviceStore } from './stores/device'

createApp({
  onLaunch() {
    createPinia()
    const store = useDeviceStore()
    store.loadDevices()
    store.loadDarkMode()
  },
})
</script>

<style>
page {
