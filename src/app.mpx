.page.dark .btn-outline { border-color: var(--color-primary); color: var(--color-primary); }
.page.dark .field-input { background: #1a1a2e; border-color: var(--color-primary); color: var(--color-text); }
.page.dark .sel-option { background: #1a1a2e; border-color: #2a2a44; }
.page.dark .sel-active { background: rgba(0,255,65,0.08); border-color: var(--color-primary); }
.page.dark .history-item { background: var(--color-card); }
